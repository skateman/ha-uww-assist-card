{
  "name": "ha-uww-assist-card",
  "version": "0.0.3",
  "private": true,
  "description": "Home Assistant Lovelace custom card: in-browser microWakeWord detection that triggers HA's built-in Assist voice dialog.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skateman/ha-uww-assist-card.git"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "wake-word",
    "microwakeword",
    "assist",
    "voice"
  ],
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs-backend-cpu": "4.9.0",
    "@tensorflow/tfjs-core": "4.9.0",
    "@tensorflow/tfjs-tflite": "0.0.1-alpha.10",
    "lit": "^3.3.0",
    "uww.js": "^0.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "rollup": "^4.60.0",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0"
  }
}
